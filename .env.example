# === LLM Provider API Keys ===
# Fill in only the providers you want to use. Ollama needs no key.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# === Tool API Keys ===
OPENWEATHERMAP_API_KEY=your_owm_key_here
TAVILY_API_KEY=tvly-...

# === Ollama (local models) ===
# Points to the Ollama docker service defined in docker-compose.yml
OLLAMA_BASE_URL=http://ollama:11434

# === Database ===
DATABASE_URL=sqlite:////app/data/agent.db

# === App Settings ===
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=10
